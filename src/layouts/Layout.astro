---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
}

const { 
  title,
  description = "Tyler Myles — Game Developer & Audio Engineer specializing in Unreal Engine C++ development, prediction rollback systems, and modern metal mixing and mastering.",
  canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://tylermyles.dev').href
} = Astro.props;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Tyler Myles",
  "url": "https://tylermyles.dev",
  "jobTitle": ["Game Developer", "Audio Engineer", "Unreal Engine Specialist", "Modern Metal Producer"],
  "description": description,
  "sameAs": [
    "https://www.youtube.com/@interlvper",
    "https://github.com/Interlvper",
    "https://www.instagram.com/tylerjmyles/"
  ]
};
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="canonical" href={canonicalURL}>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonicalURL}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:site_name" content="Tyler Myles Portfolio">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:url" content={canonicalURL}>
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>

    <!-- JSON-LD Structured Data for SEO -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;500;800&family=JetBrains+Mono:wght@400;700&display=swap"
        rel="stylesheet">
</head>
<body>
    <slot />
</body>
</html>
