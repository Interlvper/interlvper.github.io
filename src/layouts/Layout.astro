---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
}

const { 
  title,
  description = "Tyler Myles — Game Developer & Audio Engineer specializing in Unreal Engine C++ development, prediction rollback systems, and modern metal mixing and mastering.",
  canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://tylermyles.dev').href
} = Astro.props;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Tyler Myles",
  "url": "https://tylermyles.dev",
  "jobTitle": ["Game Developer", "Unreal Engine C++ Programmer", "Audio Engineer", "Modern Metal Producer"],
  "description": description,
  "knowsAbout": [
    "Unreal Engine 5", "C++", "Game Development", "Multiplayer Networking",
    "Prediction Rollback Systems", "Technical Art", "Blueprints", "Game AI",
    "Inventory Systems", "Ballistics Simulation", "Plugin Development",
    "Audio Mixing", "Audio Mastering", "Modern Metal Production", "Songwriting"
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Santa Fe",
    "addressRegion": "NM",
    "addressCountry": "US"
  },
  "sameAs": [
    "https://www.linkedin.com/in/tyler-j-myles/",
    "https://www.youtube.com/@interlvper",
    "https://github.com/Interlvper",
    "https://www.instagram.com/tylerjmyles/",
    "https://www.fiverr.com/users/tylerjmyles",
    "https://interlvper.itch.io/"
  ]
};
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="keywords" content="game developer, Unreal Engine developer, UE5 C++ programmer, game programmer for hire, freelance game developer, Unreal Engine specialist, prediction rollback systems, multiplayer game developer, modern metal mixing, mastering engineer, audio production, Santa Fe game developer">
    <meta name="theme-color" content="#050403">
    <link rel="canonical" href={canonicalURL}>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonicalURL}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:site_name" content="Tyler Myles Portfolio">
    <meta property="og:image" content="https://tylermyles.dev/images/og-preview.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content={canonicalURL}>
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content="https://tylermyles.dev/images/og-preview.png">

    <!-- JSON-LD Structured Data for SEO -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;500;800&family=JetBrains+Mono:wght@400;700&display=swap"
        rel="stylesheet">
</head>
<body>
    <slot />
</body>
</html>
