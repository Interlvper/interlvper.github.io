---
import type { PriceCategory } from '../data/pricing';

interface Props {
  category: PriceCategory;
}

const { category } = Astro.props;
---

<div class="data-block pricing-glow">
    <h3 style="color: var(--accent-pricing);">{category.title}</h3>
    <p style="margin-bottom: 20px;">{category.description}</p>
    <div class="price-list">
        {category.items.map(item => (
            <div class="price-item">
                <span class="price-service">{item.service}</span>
                <span class="price-cost cost-pricing">{item.cost}</span>
            </div>
        ))}
    </div>
</div>
