---
import type { GameSystem } from '../data/games';

interface Props {
  title: string;
  desc: string;
}

const { title, desc } = Astro.props;
---

<div class="system-card">
    <div class="system-card-header">
        <span class="system-card-indicator"></span>
        <h6 class="system-card-title">{title}</h6>
    </div>
    <p class="system-card-desc">{desc}</p>
</div>
