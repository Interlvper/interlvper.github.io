---
// GitHub repos fetched at build time for SEO crawlability
interface GitHubRepo {
  name: string;
  description: string | null;
  stargazers_count: number;
  language: string | null;
  html_url: string;
  fork: boolean;
}

let repos: GitHubRepo[] = [];

try {
  const response = await fetch('https://api.github.com/users/Interlvper/repos?sort=updated&per_page=10');
  if (response.ok) {
    const allRepos: GitHubRepo[] = await response.json();
    repos = allRepos
      .filter(repo => !repo.fork && repo.name.toLowerCase() !== 'interlvper.github.io')
      .slice(0, 6);
  }
} catch (error) {
  console.error('Error fetching GitHub repos at build time:', error);
}
---

<div id="github-repos-container" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr)); gap: 20px;">
    {repos.length > 0 ? (
        repos.map(repo => (
            <div class="nested-block">
                <h4 style="text-transform: none;">{repo.name}</h4>
                <div style="margin-bottom: 15px; font-family: var(--font-mono); font-size: 0.85rem; color: var(--fg-main);">
                    <span style="color: var(--accent-dev); margin-right: 15px; text-shadow: 0 0 8px rgba(0, 208, 255, 0.4);">★ {repo.stargazers_count}</span>
                    {repo.language && <span>{repo.language}</span>}
                </div>
                <p>{repo.description || 'No description provided for this repository.'}</p>
                <a href={repo.html_url} target="_blank" rel="noopener noreferrer" class="btn-action" style="margin-top: auto;">View Source</a>
            </div>
        ))
    ) : (
        <p style="color: var(--fg-dim); font-family: var(--font-mono);">No public repositories found.</p>
    )}
</div>
