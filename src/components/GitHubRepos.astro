---
// GitHub repos are fetched client-side since the API is dynamic
---

<div id="github-repos-container" class="data-grid" style="margin-bottom: 60px;">
    <p id="github-loading" style="color: var(--accent-pricing); font-family: var(--font-mono); animation: blink 1s infinite;">
        Fetching network data from GitHub API...
    </p>
</div>

<script>
    async function fetchGitHubRepos() {
        const container = document.getElementById('github-repos-container');
        if (!container) return;
        const username = 'Interlvper';

        try {
            const response = await fetch(`https://api.github.com/users/${username}/repos?sort=updated&per_page=10`);
            if (!response.ok) throw new Error('Network response was not ok');

            const repos = await response.json();
            const originalRepos = repos.filter((repo: any) => !repo.fork && repo.name.toLowerCase() !== 'interlvper.github.io').slice(0, 6);

            container.innerHTML = '';
            if (originalRepos.length === 0) {
                container.innerHTML = '<p style="color: var(--fg-dim); font-family: var(--font-mono);">No public repositories found for this user.</p>';
                return;
            }

            originalRepos.forEach((repo: any) => {
                const repoEl = document.createElement('div');
                repoEl.className = 'data-block git-glow inner-card';
                const description = repo.description || 'No description provided for this repository.';

                repoEl.innerHTML = `
                    <h3 style="color: var(--accent-github); text-transform: none; font-size: 1.25rem;">${repo.name}</h3>
                    <div style="margin-bottom: 15px; font-family: var(--font-mono); font-size: 0.85rem; color: var(--fg-main);">
                        <span style="color: var(--accent-dev); margin-right: 15px; text-shadow: 0 0 8px rgba(0, 208, 255, 0.4);">★ ${repo.stargazers_count}</span>
                        ${repo.language ? `<span>${repo.language}</span>` : ''}
                    </div>
                    <p>${description}</p>
                    <a href="${repo.html_url}" target="_blank" class="btn-action btn-github" style="margin-top: auto;">View Source</a>
                `;
                container.appendChild(repoEl);
            });
        } catch (error) {
            console.error('Error fetching GitHub repos:', error);
            container.innerHTML = '<p style="color: var(--accent-prod); font-family: var(--font-mono);">Failed to load repositories from GitHub. Please try again later.</p>';
        }
    }

    fetchGitHubRepos();
</script>
