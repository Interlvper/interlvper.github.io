---
import type { Review } from '../data/reviews';

interface Props {
  review: Review;
}

const { review } = Astro.props;
---

<div class="nested-block">
    <div class="stars">★★★★★</div>
    <p class="review-text">"{review.text}"</p>
    <p class="review-author">{review.author}</p>
    <a href="https://www.fiverr.com/users/tylerjmyles" target="_blank" rel="noopener noreferrer" class="verify-link">↗ Verified on Fiverr</a>
</div>
