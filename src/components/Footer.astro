---
// Footer.astro — Site footer component matching the Nostromo terminal aesthetic
import { SOCIAL_LINKS } from '../data/navigation';
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
    <div class="footer-content">
        <div class="footer-meta">
            <p>&copy; {currentYear} Tyler Myles. All rights reserved.</p>
        </div>
        <div class="footer-socials">
            {SOCIAL_LINKS.map(social => (
                <a href={social.url} target="_blank" rel="noopener noreferrer" title={social.title}>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <Fragment set:html={social.svg} />
                    </svg>
                </a>
            ))}
        </div>
    </div>
</footer>
