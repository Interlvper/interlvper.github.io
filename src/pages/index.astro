---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HomePanel from '../components/HomePanel.astro';
import DevPanel from '../components/DevPanel.astro';
import ProdPanel from '../components/ProdPanel.astro';
import PricingPanel from '../components/PricingPanel.astro';
import ContactPanel from '../components/ContactPanel.astro';
import Footer from '../components/Footer.astro';

import Dock from '../components/Dock.astro';
---

<Layout 
    title="Tyler Myles | Game Developer & Audio Engineer"
    description="Portfolio of Tyler Myles — Unreal Engine C++ specialist, technical artist, and professional modern metal mixing and mastering engineer."
>
    <Header />
    <Dock />
    <main class="viewport">
        <HomePanel />
        <DevPanel />
        <ProdPanel />
        <PricingPanel />
        <ContactPanel />
        <Footer />

    </main>
</Layout>

<script>
    function initAnimations() {
        const panels = document.querySelectorAll('.panel');
        
        const observerOptions = {
            root: null,
            rootMargin: '0px 0px -10% 0px',
            threshold: 0.05
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        panels.forEach(panel => {
            if (panel.id === 'panel-home') {
                panel.classList.add('is-visible');
            } else {
                observer.observe(panel);
            }
        });
    }

    document.addEventListener('DOMContentLoaded', initAnimations);
    document.addEventListener('astro:page-load', initAnimations);
</script>
